generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String
  surname       String?
  phone         String
  chatId        BigInt @unique
  @@map("users")
}

model Task {
  id              String   @id @default(cuid())
  name           String
  description     String?
  importanceLevel String   // 'high', 'medium', 'low'
  chatId          BigInt
  createdAt       DateTime @default(now())

  @@map("tasks")
}